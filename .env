# ─── IntegraJobs — Variables de entorno ───────────────────────────
# Copia este archivo como `.env` en la raíz y rellena los valores.
# NUNCA subas tu .env al repositorio.

# ─── Base de datos (PostgreSQL en Docker) ─────────────────────────
# IMPORTANTE: puerto 5434 — es el puerto EXPUESTO al host.
# Internamente el contenedor usa 5432, pero desde tu máquina (y
# desde Prisma CLI corriendo en el host) siempre se usa 5434.
DATABASE_URL="postgresql://portal:portal_secret@localhost:5434/portal_db"

# ─── NextAuth (frontend) ──────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia_este_secreto_en_produccion"

# ─── Backend API ──────────────────────────────────────────────────
JWT_SECRET="cambia_este_secreto_en_produccion"
PORT=3000
NODE_ENV=development
